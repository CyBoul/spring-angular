<configuration>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss} %highlight(%-5level) %cyan(%-30.30logger{30}) : %msg%n</pattern>
        </encoder>
    </appender>

    <!-- App -->
    <logger name="com.cyboul.demo" level="DEBUG"/>

    <!-- Spring -->
    <logger name="org.springframework.boot"    level="INFO"/>
    <logger name="org.springframework.web"     level="WARN"/>
    <logger name="org.springframework.security" level="WARN"/>

    <!-- Noisy infra -->
    <logger name="com.zaxxer.hikari"           level="WARN"/>
    <logger name="org.hibernate"               level="WARN"/>
    <logger name="org.hibernate.SQL"           level="WARN"/>
    <logger name="org.apache.catalina"         level="WARN"/>
    <logger name="org.apache.tomcat"           level="WARN"/>
    <logger name="org.springdoc"               level="WARN"/>
    <logger name="org.springframework.boot.docker.compose" level="INFO"/>

    <root level="WARN">
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>
